generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  isAdmin       Boolean   @default(false)
  paypalEmail   String?   // for receiving payouts
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  adViews   AdView[]
  earnings  Earning[]
  entries   LotteryEntry[]
  payouts   Payout[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AdView {
  id        String   @id @default(cuid())
  userId    String
  viewedAt  DateTime @default(now())
  date      String   // YYYY-MM-DD format for daily tracking
  adRevenue Float    @default(0.001)

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lotteryEntry  LotteryEntry?

  @@unique([userId, date])
}

model LotteryEntry {
  id          String   @id @default(cuid())
  userId      String
  adViewId    String   @unique
  date        String   // YYYY-MM-DD
  enteredAt   DateTime @default(now())
  isWinner    Boolean  @default(false)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  adView  AdView  @relation(fields: [adViewId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model LotteryDraw {
  id             String   @id @default(cuid())
  date           String   @unique // YYYY-MM-DD
  totalPool      Float    @default(0)
  totalViews     Int      @default(0)
  winnersCount   Int      @default(0)
  prizePerWinner Float    @default(0)
  drawnAt        DateTime @default(now())
  winnerIds      String   @default("[]") // JSON array of user IDs
  payoutStatus   String   @default("pending") // pending | processing | complete | partial
  paypalBatchId  String?  // PayPal payout batch ID
}

model Earning {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  date          String   // YYYY-MM-DD
  drawId        String?
  paymentStatus String   @default("pending") // pending | processing | paid | failed | no_paypal
  paymentTxId   String?  // PayPal transaction ID
  createdAt     DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  payout Payout?
}

// Tracks individual PayPal payout items
model Payout {
  id          String   @id @default(cuid())
  userId      String
  earningId   String   @unique
  amount      Float
  currency    String   @default("USD")
  paypalEmail String
  paypalTxId  String?  // PayPal item transaction ID
  batchId     String?  // PayPal batch ID
  status      String   @default("pending") // pending | processing | success | failed | unclaimed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  earning Earning @relation(fields: [earningId], references: [id], onDelete: Cascade)
}

model DailyPool {
  id        String   @id @default(cuid())
  date      String   @unique // YYYY-MM-DD
  totalPool Float    @default(0)
  viewCount Int      @default(0)
  drawn     Boolean  @default(false)
  updatedAt DateTime @updatedAt
}
